# Root-level environment variables for Docker Compose
# Copy to .env and adjust as needed

# PostgreSQL
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app

# MongoDB (no auth by default)
MONGO_INITDB_DATABASE=ai_habit

# NestJS API
DATABASE_URL=postgresql://app:app@postgres:5432/app
MONGO_URL=mongodb://mongo:27017
AI_BASE_URL=http://ai:8000

# Demo client (browser-side, must use localhost)
VITE_API_BASE_URL=http://localhost:3000

# Google Calendar (Phase 4)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Firebase Cloud Messaging (Phase 4)
FCM_TEST_TOKEN=your_fcm_device_registration_token

# Elasticsearch (Phase 5)
ELASTICSEARCH_HOST=http://elasticsearch:9200
